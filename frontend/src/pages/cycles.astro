---
import AppShell from '../components/AppShell.astro';
import PageCard from '../components/PageCard.astro';
import StatusBadge from '../components/StatusBadge.astro';
import { getSession } from '../lib/auth';
import { loadCurrentSummary, loadCycles, loadDashboard } from '../lib/api';
import { formatYen } from '../lib/format';

const session = getSession(Astro.cookies);
if (!session) return Astro.redirect('/login');

const [cycles, summary, dashboard] = await Promise.all([
  loadCycles(session),
  loadCurrentSummary(session).catch(() => null),
  loadDashboard(session).catch(() => null),
]);
const error = Astro.url.searchParams.get('error');
const today = new Date().toISOString().slice(0, 10);
---

<AppShell title="予算周期" description="現在の周期と、過去の周期を管理する。" active="cycles">
  {error ? <div class="badge danger">保存に失敗しました: {error}</div> : null}

  <div class="grid two-col">
    <PageCard title="周期を追加">
      <form method="post" action="/api/cycles/create" class="stack">
        <div class="field-grid">
          <label class="field">
            <span>名称</span>
            <input name="name" placeholder="2026年6月" required />
          </label>
          <label class="field">
            <span>リセット種別</span>
            <select name="resetType" required>
              <option value="calendar_based">月初〜月末</option>
              <option value="salary_based">給与日基準</option>
              <option value="custom">カスタム</option>
            </select>
          </label>
          <label class="field">
            <span>開始日</span>
            <input name="startDate" type="date" value={today} required />
          </label>
          <label class="field">
            <span>終了日</span>
            <input name="endDate" type="date" value={today} required />
          </label>
        </div>
        <button class="primary-button" type="submit">周期を作成</button>
      </form>
    </PageCard>

    <PageCard title="現在の周期">
      {summary ? (
        <div class="stack">
          <div>
            <div class="label">周期名</div>
            <strong>{dashboard?.currentCycle.name ?? summary.cycleId}</strong>
          </div>
          <div class="field-grid">
            <div class="summary-card">
              <div class="label">限度額</div>
              <div class="value">{formatYen(summary.spendingLimit)}</div>
              <div class="note">今期の基準値</div>
            </div>
            <div class="summary-card">
              <div class="label">残額</div>
              <div class="value">{formatYen(summary.remainingAmount)}</div>
              <div class="note">{summary.pace.isOverPace ? 'ペース超過' : '想定内'}</div>
            </div>
          </div>
          <StatusBadge tone={summary.pace.isOverPace ? 'danger' : 'success'}>
            {summary.pace.isOverPace ? 'ペース超過' : '順調'}
          </StatusBadge>
        </div>
      ) : (
        <p class="muted">現在の周期を取得できませんでした。</p>
      )}
    </PageCard>
  </div>

  <PageCard title="周期一覧">
    <div class="table-wrapper">
      <table>
        <thead>
          <tr>
            <th>名称</th>
            <th>期間</th>
            <th>種別</th>
            <th>状態</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          {cycles.map((cycle) => (
            <tr>
              <td>{cycle.name}</td>
              <td>{cycle.startDate} 〜 {cycle.endDate}</td>
              <td>{cycle.resetType}</td>
              <td>
                <StatusBadge tone={cycle.isClosed ? 'warning' : 'success'}>
                  {cycle.isClosed ? '終了' : '進行中'}
                </StatusBadge>
              </td>
              <td class="form-actions">
                {!cycle.isClosed ? (
                  <form method="post" action={`/api/cycles/${cycle.id}/close`}>
                    <input type="hidden" name="carryoverPolicy" value="keep_as_remaining" />
                    <button class="ghost-button" type="submit">閉じる</button>
                  </form>
                ) : null}
                <form method="post" action={`/api/cycles/${cycle.id}/delete`}>
                  <button class="ghost-button" type="submit">削除</button>
                </form>
              </td>
            </tr>
          ))}
          {cycles.length === 0 ? (
            <tr>
              <td colspan="5" class="muted">周期がまだ登録されていません。</td>
            </tr>
          ) : null}
        </tbody>
      </table>
    </div>
  </PageCard>
</AppShell>
