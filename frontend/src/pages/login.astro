---
import Base from '../layouts/Base.astro';
import AuthScreen from '../components/AuthScreen';
import { getPublicAuthMode, getSession } from '../lib/server/auth';
if (await getSession(Astro.cookies)) return Astro.redirect('/dashboard');
---
<Base title="ログイン | Pocket Pace"><AuthScreen client:load mode="login" authMode={getPublicAuthMode()} error={Astro.url.searchParams.get('error') ?? undefined}/></Base>
