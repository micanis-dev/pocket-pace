---
import Base from '../layouts/Base.astro';
import AuthScreen from '../components/AuthScreen';
import { getPublicAuthMode, getSession } from '../lib/server/auth';
if (await getSession(Astro.cookies)) return Astro.redirect('/dashboard');
---
<Base title="新規登録 | Pocket Pace"><AuthScreen client:load mode="signup" authMode={getPublicAuthMode()} error={Astro.url.searchParams.get('error') ?? undefined} initialEmail={Astro.url.searchParams.get('email') ?? ''}/></Base>
