---
import AppShell from '../components/AppShell.astro';
import PageCard from '../components/PageCard.astro';
import StatusBadge from '../components/StatusBadge.astro';
import { getSession } from '../lib/auth';
import { loadDashboard } from '../lib/api';
import { formatDate, formatNumber, formatYen } from '../lib/format';

const session = getSession(Astro.cookies);
if (!session) return Astro.redirect('/login');

const dashboard = await loadDashboard(session).catch(() => null);

const progress = dashboard
  ? Math.min(100, Math.max(0, (dashboard.budgetSummary.availablePerUnit / Math.max(1, dashboard.budgetSummary.spendingLimit)) * 100))
  : 0;
---

<AppShell title="ホーム" description="現在の予算周期と、今すぐ使える金額を確認する。" active="dashboard">
  {dashboard ? null : (
    <PageCard title="データを取得できません">
      <div class="stack">
        <p class="muted">
          API に接続できないか、認証セッションが有効ではありません。ログインし直すか、API の設定を確認してください。
        </p>
        <div class="form-actions">
          <a class="primary-button" href="/login">ログイン画面へ戻る</a>
          <form method="post" action="/auth/logout">
            <button class="secondary-button" type="submit">ログアウト</button>
          </form>
        </div>
      </div>
    </PageCard>
  )}

  {dashboard ? (
    <>
  <div class="grid summary">
    <div class="summary-card">
      <div class="label">現在の周期</div>
      <div class="value">{dashboard.currentCycle.name}</div>
      <div class="note">{dashboard.currentCycle.startDate} 〜 {dashboard.currentCycle.endDate}</div>
    </div>
    <div class="summary-card">
      <div class="label">使用限度額</div>
      <div class="value">{formatYen(dashboard.budgetSummary.spendingLimit)}</div>
      <div class="note">今期の基準金額</div>
    </div>
    <div class="summary-card">
      <div class="label">残額</div>
      <div class={`value ${dashboard.budgetSummary.remainingAmount < 0 ? 'danger' : ''}`}>
        {formatYen(dashboard.budgetSummary.remainingAmount)}
      </div>
      <div class="note">使用後に残る金額</div>
    </div>
    <div class="summary-card">
      <div class="label">表示粒度</div>
      <div class="value">{dashboard.budgetSummary.unitLabel}</div>
      <div class="note">1単位あたり {formatYen(dashboard.budgetSummary.availablePerUnit)}</div>
    </div>
  </div>

  <div class="grid two-col">
    <PageCard title="使用ペース">
      <StatusBadge slot="action" tone={dashboard.budgetSummary.isOverPace ? 'danger' : 'success'}>
        {dashboard.budgetSummary.isOverPace ? 'ペース超過' : '順調'}
      </StatusBadge>
      <div class="stack">
        <div>
          <div class="label">消費進捗</div>
          <div class="progress" aria-label="usage progress">
            <span style={`width: ${progress}%`} />
          </div>
          <div class="note">{formatNumber(Math.round(progress))}%</div>
        </div>

        <div class="field-grid">
          <div class="summary-card">
            <div class="label">直近の支出数</div>
            <div class="value">{dashboard.recentExpenses.length}</div>
            <div class="note">ホームには最新5件を表示</div>
          </div>
          <div class="summary-card">
            <div class="label">周期状態</div>
            <div class="value">{dashboard.currentCycle.isClosed ? '終了' : '進行中'}</div>
            <div class="note">表示はサーバーで取得</div>
          </div>
        </div>
      </div>
    </PageCard>

    <PageCard title="クイックリンク">
      <div class="stack">
        <a class="primary-button" href="/expenses">支出を確認する</a>
        <a class="secondary-button" href="/incomes">収入を確認する</a>
        <a class="secondary-button" href="/accounts">口座を管理する</a>
        <a class="secondary-button" href="/statements">請求を照合する</a>
      </div>
    </PageCard>
  </div>

  <PageCard title="直近の支出">
    <div class="table-wrapper">
      <table>
        <thead>
          <tr>
            <th>日付</th>
            <th>支出名</th>
            <th>金額</th>
            <th>支払い方法</th>
            <th>メモ</th>
          </tr>
        </thead>
        <tbody>
          {dashboard.recentExpenses.map((expense) => (
            <tr>
              <td>{formatDate(expense.expenseDate)}</td>
              <td>{expense.name}</td>
              <td>{formatYen(expense.amount)}</td>
              <td>{expense.paymentMethod}</td>
              <td>{expense.memo ?? '-'}</td>
            </tr>
          ))}
          {dashboard.recentExpenses.length === 0 ? (
            <tr>
              <td colspan="5" class="muted">まだ支出がありません。</td>
            </tr>
          ) : null}
        </tbody>
      </table>
    </div>
  </PageCard>
    </>
  ) : null}
</AppShell>
