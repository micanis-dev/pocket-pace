---
import AppShell from '../components/AppShell.astro';
import PageCard from '../components/PageCard.astro';
import StatusBadge from '../components/StatusBadge.astro';
import { getSession } from '../lib/auth';
import { loadAccounts, loadCards } from '../lib/api';

const session = getSession(Astro.cookies);
if (!session) return Astro.redirect('/login');

const [cards, accounts] = await Promise.all([loadCards(session), loadAccounts(session)]);
const error = Astro.url.searchParams.get('error');
---

<AppShell title="カード管理" description="クレジットカードと引き落とし口座を管理する。" active="cards">
  {error ? <div class="badge danger">保存に失敗しました: {error}</div> : null}

  <PageCard title="カードを追加">
    <form method="post" action="/api/cards/create" class="stack">
      <div class="field-grid">
        <label class="field">
          <span>カード名</span>
          <input name="name" placeholder="楽天カード" required />
        </label>
        <label class="field">
          <span>引き落とし口座</span>
          <select name="withdrawalAccountId" required>
            <option value="">選択してください</option>
            {accounts.map((account) => (
              <option value={account.id}>{account.name}</option>
            ))}
          </select>
        </label>
        <label class="field">
          <span>締め日</span>
          <input name="closingDay" type="number" min="1" max="31" value="31" required />
        </label>
        <label class="field">
          <span>引き落とし日</span>
          <input name="paymentDay" type="number" min="1" max="31" value="27" required />
        </label>
      </div>
      <button class="primary-button" type="submit">カードを作成</button>
    </form>
  </PageCard>

  <PageCard title="カード一覧">
    <div class="table-wrapper">
      <table>
        <thead>
          <tr>
            <th>名称</th>
            <th>締め日</th>
            <th>引き落とし日</th>
            <th>口座</th>
            <th>状態</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          {cards.map((card) => (
            <tr>
              <td>{card.name}</td>
              <td>{card.closingDay}日</td>
              <td>{card.paymentDay}日</td>
              <td>{accounts.find((account) => account.id === card.withdrawalAccountId)?.name ?? card.withdrawalAccountId}</td>
              <td>
                <StatusBadge tone={card.isActive ? 'success' : 'danger'}>
                  {card.isActive ? '有効' : '無効'}
                </StatusBadge>
              </td>
              <td>
                <form method="post" action={`/api/cards/${card.id}/delete`}>
                  <button class="ghost-button" type="submit">削除</button>
                </form>
              </td>
            </tr>
          ))}
          {cards.length === 0 ? (
            <tr>
              <td colspan="6" class="muted">カードがまだ登録されていません。</td>
            </tr>
          ) : null}
        </tbody>
      </table>
    </div>
  </PageCard>
</AppShell>
