---
import AppShell from '../components/AppShell.astro';
import PageCard from '../components/PageCard.astro';
import StatusBadge from '../components/StatusBadge.astro';
import { getSession } from '../lib/auth';
import { loadAccounts, loadCurrentSummary } from '../lib/api';
import { formatYen } from '../lib/format';

const session = getSession(Astro.cookies);
if (!session) return Astro.redirect('/login');

const [accounts, summary] = await Promise.all([
  loadAccounts(session),
  loadCurrentSummary(session).catch(() => null),
]);

const activeAccounts = accounts.filter((account) => account.isActive);
const totalBalance = activeAccounts.reduce((sum, account) => sum + account.currentBalance, 0);
const today = new Date().toISOString().slice(0, 10);
const error = Astro.url.searchParams.get('error');
---

<AppShell title="口座管理" description="銀行口座、財布、現金、電子マネーの残高を管理する。" active="accounts">
  {error ? <div class="badge danger">保存に失敗しました: {error}</div> : null}

  <div class="grid summary">
    <div class="summary-card">
      <div class="label">口座数</div>
      <div class="value">{accounts.length}</div>
      <div class="note">有効: {activeAccounts.length}</div>
    </div>
    <div class="summary-card">
      <div class="label">残高合計</div>
      <div class="value">{formatYen(totalBalance)}</div>
      <div class="note">有効口座のみ集計</div>
    </div>
    <div class="summary-card">
      <div class="label">今期</div>
      <div class="value">{summary?.period?.startDate ?? '-'}</div>
      <div class="note">{summary?.period?.endDate ?? '-'}</div>
    </div>
    <div class="summary-card">
      <div class="label">使用限度額</div>
      <div class="value">{summary ? formatYen(summary.spendingLimit) : '-'}</div>
      <div class="note">周期集計はホームで確認</div>
    </div>
  </div>

  <div class="grid two-col">
    <PageCard title="口座を追加">
      <form method="post" action="/api/accounts/create" class="stack">
        <div class="field-grid">
          <label class="field">
            <span>口座名</span>
            <input name="name" placeholder="メイン口座" required />
          </label>
          <label class="field">
            <span>種類</span>
            <select name="type" required>
              <option value="bank">銀行口座</option>
              <option value="wallet">財布</option>
              <option value="cash_box">タンス預金</option>
              <option value="electronic_money">電子マネー</option>
              <option value="other">その他</option>
            </select>
          </label>
          <label class="field">
            <span>初期残高</span>
            <input name="initialBalance" type="number" value="0" min="0" required />
          </label>
          <label class="field">
            <span>作成日</span>
            <input value={today} disabled />
          </label>
        </div>
        <button class="primary-button" type="submit">口座を作成</button>
      </form>
    </PageCard>

    <PageCard title="メモ">
      <div class="stack">
        <p class="muted">
          口座の残高は支出・収入・資金移動と連動して更新されます。ここでは入力済みの残高を確認できます。
        </p>
        <StatusBadge tone="success">残高は同期済み</StatusBadge>
      </div>
    </PageCard>
  </div>

  <PageCard title="口座一覧">
    <div class="table-wrapper">
      <table>
        <thead>
          <tr>
            <th>名称</th>
            <th>種類</th>
            <th>初期残高</th>
            <th>現在残高</th>
            <th>状態</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          {accounts.map((account) => (
            <tr>
              <td>{account.name}</td>
              <td>{account.type}</td>
              <td>{formatYen(account.initialBalance)}</td>
              <td>{formatYen(account.currentBalance)}</td>
              <td>
                <StatusBadge tone={account.isActive ? 'success' : 'danger'}>
                  {account.isActive ? '有効' : '無効'}
                </StatusBadge>
              </td>
              <td>
                <form method="post" action={`/api/accounts/${account.id}/delete`}>
                  <button class="ghost-button" type="submit">削除</button>
                </form>
              </td>
            </tr>
          ))}
          {accounts.length === 0 ? (
            <tr>
              <td colspan="6" class="muted">口座がまだ登録されていません。</td>
            </tr>
          ) : null}
        </tbody>
      </table>
    </div>
  </PageCard>
</AppShell>
