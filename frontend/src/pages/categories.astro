---
import AppShell from '../components/AppShell.astro';
import PageCard from '../components/PageCard.astro';
import StatusBadge from '../components/StatusBadge.astro';
import { getSession } from '../lib/auth';
import { loadCategories } from '../lib/api';

const session = getSession(Astro.cookies);
if (!session) return Astro.redirect('/login');

const categories = await loadCategories(session);
const error = Astro.url.searchParams.get('error');
---

<AppShell title="カテゴリ設定" description="食費、固定費、サブスクなどのカテゴリを管理する。" active="categories">
  {error ? <div class="badge danger">保存に失敗しました: {error}</div> : null}

  <PageCard title="カテゴリを追加">
    <form method="post" action="/api/categories/create" class="stack">
      <div class="field-grid">
        <label class="field">
          <span>カテゴリ名</span>
          <input name="name" placeholder="食費" required />
        </label>
      </div>
      <button class="primary-button" type="submit">カテゴリを作成</button>
    </form>
  </PageCard>

  <PageCard title="カテゴリ一覧">
    <div class="table-wrapper">
      <table>
        <thead>
          <tr>
            <th>名称</th>
            <th>状態</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          {categories.map((category) => (
            <tr>
              <td>{category.name}</td>
              <td>
                <StatusBadge tone={category.isActive ? 'success' : 'danger'}>
                  {category.isActive ? '有効' : '無効'}
                </StatusBadge>
              </td>
              <td>
                <form method="post" action={`/api/categories/${category.id}/delete`}>
                  <button class="ghost-button" type="submit">削除</button>
                </form>
              </td>
            </tr>
          ))}
          {categories.length === 0 ? (
            <tr>
              <td colspan="3" class="muted">カテゴリがまだ登録されていません。</td>
            </tr>
          ) : null}
        </tbody>
      </table>
    </div>
  </PageCard>
</AppShell>
